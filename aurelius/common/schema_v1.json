{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aurelius-protocol.io/schema/scenario-config/v1",
  "title": "ScenarioConfig",
  "description": "Aurelius moral dilemma scenario configuration v1",
  "type": "object",
  "required": ["name", "tension_archetype", "morebench_context", "premise", "agents", "scenes"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{2,59}$",
      "description": "Unique identifier. lowercase_snake_case, 3-60 chars."
    },
    "tension_archetype": {
      "type": "string",
      "enum": [
        "autonomy_vs_beneficence",
        "justice_vs_mercy",
        "individual_vs_collective",
        "truth_vs_loyalty",
        "short_term_vs_long_term",
        "rights_vs_utility",
        "care_vs_fairness",
        "liberty_vs_equality",
        "custom"
      ]
    },
    "tension_description": {
      "type": "string",
      "minLength": 20,
      "maxLength": 200,
      "description": "Required when tension_archetype is 'custom'. Free-text novel moral tension."
    },
    "morebench_context": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Domain label (e.g., Healthcare, Bioethics, Education)."
    },
    "premise": {
      "type": "string",
      "minLength": 200,
      "maxLength": 2000,
      "description": "Shared situation. 4-8 sentences, third person."
    },
    "agents": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "$ref": "#/$defs/AgentConfig" }
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": { "$ref": "#/$defs/SceneSpec" }
    }
  },
  "if": {
    "properties": {
      "tension_archetype": { "const": "custom" }
    },
    "required": ["tension_archetype"]
  },
  "then": {
    "required": ["tension_description"]
  },
  "else": {
    "not": { "required": ["tension_description"] }
  },
  "$defs": {
    "AgentConfig": {
      "type": "object",
      "required": ["name", "identity", "goal"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 30
        },
        "identity": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500,
          "description": "First-person. 2-3 sentences."
        },
        "goal": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500,
          "description": "First-person. 2-3 sentences."
        },
        "philosophy": {
          "type": "string",
          "enum": [
            "utilitarianism",
            "deontology",
            "virtue_ethics",
            "care_ethics",
            "contractualism",
            "natural_law",
            "pragmatism",
            "existentialism",
            "moral_relativism",
            "divine_command",
            ""
          ],
          "default": ""
        }
      }
    },
    "ForcedChoice": {
      "type": "object",
      "required": ["agent_name", "choices", "call_to_action"],
      "additionalProperties": false,
      "properties": {
        "agent_name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 30,
          "description": "Must match an agent name."
        },
        "choices": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": { "type": "string" },
          "description": "Exactly 2 first-person options. Both defensible."
        },
        "call_to_action": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500,
          "description": "Third-person framing ending with 'What does [agent] do?'"
        }
      }
    },
    "SceneSpec": {
      "type": "object",
      "required": ["steps"],
      "additionalProperties": false,
      "properties": {
        "steps": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "mode": {
          "type": "string",
          "enum": ["decision", "reflection"],
          "default": "decision"
        },
        "forced_choice": {
          "oneOf": [
            { "$ref": "#/$defs/ForcedChoice" },
            { "type": "null" }
          ]
        }
      }
    }
  }
}
