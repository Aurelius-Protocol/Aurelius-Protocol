# =============================================================================
# Aurelius v3 (Miner / Validator) — Environment Variables
# =============================================================================
# Copy to .env and fill in the values below.
# All other settings have sane defaults — see aurelius/config.py.
#
# Setting ENVIRONMENT auto-configures: subnet ID, network, Central API URL,
# simulation pool size, and all pipeline parameters. You rarely need to
# override anything beyond what's listed here.

# Network profile — determines all network/subnet defaults
ENVIRONMENT=                           # local | testnet | mainnet

# Wallet
WALLET_NAME=
WALLET_HOTKEY=

# Validator — LLM API key for Concordia simulations (DeepSeek, OpenAI, etc.)
LLM_API_KEY=

# Miner
AXON_EXTERNAL_IP=
AXON_EXTERNAL_PORT=
